import java.util.ArrayList;
import java.util.List;

class RegistroEventos {
    private static RegistroEventos instancia;
    private List<String> eventos = new ArrayList<>();

    private RegistroEventos() {}

    public static RegistroEventos getInstancia() {
        if (instancia == null) {
            instancia = new RegistroEventos();
        }
        return instancia;
    }

    public void registrar(String evento) {
        eventos.add(evento);
    }

    public void mostrarReporte() {
        System.out.println("\n=== REPORTE DE MISIÓN ===");
        for (String e : eventos) {
            System.out.println("- " + e);
        }
    }
}
